# Telegram bot token from @BotFather
BOT_TOKEN=

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017

# MongoDB database name (defaults to "splitbot")
MONGO_DB_NAME=splitbot

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# OpenAI API key for NLP expense extraction
OPENAI_API_KEY=
# Model to use (defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# ExchangeRate-API key (optional — falls back to free open.er-api.com)
EXCHANGE_RATE_API_KEY=

# Webhook mode (leave blank for long-polling in development)
# Public HTTPS URL where Telegram sends updates (e.g. https://your-domain.com)
TELEGRAM_WEBHOOK_URL=
# Secret token for webhook header validation (generate a random string)
TELEGRAM_WEBHOOK_SECRET=

# TMA (Telegram Mini App) settings
# Public HTTPS URL where the webapp is hosted (e.g. https://your-domain.com)
WEBAPP_BASE_URL=
# Port for the local TMA API + static server (default: 8080)
TMA_PORT=8080
